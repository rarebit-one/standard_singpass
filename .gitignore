# Sorbet generated RBIs — committed on a separate flow via /publish-gem.
# Local tapioca runs may leave staged files; we keep them out of bulk commits
# until the publish workflow regenerates and commits them deliberately.
# (Mirrors standard_audit / standard_id convention.)
sorbet/rbi/gems/*.rbi
